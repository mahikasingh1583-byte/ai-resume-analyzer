# ── LLM Backend: "anthropic" | "openai" | "ollama" ───────────
LLM_BACKEND=openai
OPENAI_API_KEY=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
USE_FIRECRAWL=false
USE_RAG=false
USE_CREW=false

# ── Phase 1 API Keys ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# ── Phase 2: Firecrawl ───────────────────────────────────────
